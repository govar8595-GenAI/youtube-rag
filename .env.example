# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: LLM model overrides ────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: Vector store ────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=faiss      # "faiss" or "chroma"
VECTOR_STORE_DIR=vector_store

# ── Optional: Web search (provide ONE) ───────────────────────────────────────
TAVILY_API_KEY=tvly-...         # https://tavily.com (recommended, free tier)
SERPAPI_API_KEY=                # https://serpapi.com
# DuckDuckGo needs no key — used as automatic fallback

# ── Optional: Retrieval tuning ────────────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=150
CONFIDENCE_THRESHOLD=0.6
